      "title": { "en": "Cause", "nl": "Oorzaak", "de": "Ursache" }, "example": "Defective train" },
    { "name": "situation", "type": "string",
      "title": { "en": "Situation", "nl": "Situatie", "de": "Situation" }, "example": "Fewer trains" },
    { "name": "period", "type": "string",
      "title": { "en": "Period", "nl": "Periode", "de": "Zeitraum" }, "example": "until approx. 18:30" },
    { "name": "affected_stations", "type": "string",
      "title": { "en": "Affected stations", "nl": "Betrokken stations", "de": "Betroffene Bahnhöfe" }, "example": "Utrecht Centraal, Amersfoort" }
  ]
