{
  "id": "trip_departure_changed",
  "title": {
    "en": "Next train changed",
    "nl": "Volgende trein gewijzigd",
    "de": "Nächster Zug geändert"
  },
  "titleFormatted": {
    "en": "Next train on this route changed",
    "nl": "Volgende trein op dit traject is gewijzigd",
