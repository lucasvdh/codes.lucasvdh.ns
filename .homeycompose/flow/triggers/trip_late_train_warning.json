{
  "id": "trip_late_train_warning",
  "title": {
    "en": "Late train approaching",
    "nl": "Late trein nadert",
    "de": "Später Zug nähert sich"
  },
  "titleFormatted": {
    "en": "[[which]] train of the night departs in [[minutes_before]] min",
    "nl": "[[which]] trein van de avond vertrekt over [[minutes_before]] min",
    "de": "[[which]] Zug des Abends fährt in [[minutes_before]] Min"
  },
  "args": [
    { "name": "device", "type": "device", "filter": "driver_id=trip" },
    {
      "name": "which",
      "type": "dropdown",
      "title": { "en": "Which train", "nl": "Welke trein", "de": "Welcher Zug" },
      "values": [
        { "id": "last",           "label": { "en": "Last train",          "nl": "Laatste trein",         "de": "Letzter Zug" } },
        { "id": "second_to_last", "label": { "en": "Second-to-last train","nl": "Een na laatste trein",  "de": "Vorletzter Zug" } }
      ]
    },
    {
      "name": "minutes_before",
      "type": "number",
      "title": { "en": "Minutes before departure", "nl": "Minuten voor vertrek", "de": "Minuten vor Abfahrt" },
      "min": 1, "max": 180, "step": 1,
      "placeholder": { "en": "25", "nl": "25", "de": "25" }
    }
  ],
  "tokens": [
    { "name": "departure_time", "type": "string",
      "title": { "en": "Departure", "nl": "Vertrek", "de": "Abfahrt" }, "example": "23:35" },
    { "name": "destination", "type": "string",
      "title": { "en": "Destination", "nl": "Bestemming", "de": "Ziel" }, "example": "Kropswolde" },
    { "name": "track", "type": "string",
      "title": { "en": "Track", "nl": "Spoor", "de": "Gleis" }, "example": "5a" },
    { "name": "delay_minutes", "type": "number",
      "title": { "en": "Delay (min)", "nl": "Vertraging (min)", "de": "Verspätung (Min)" }, "example": 0 },
    { "name": "cancelled", "type": "boolean",
      "title": { "en": "Cancelled", "nl": "Uitgevallen", "de": "Ausgefallen" }, "example": false },
    { "name": "which", "type": "string",
      "title": { "en": "Which train", "nl": "Welke trein", "de": "Welcher Zug" }, "example": "second_to_last" },
    { "name": "minutes_until", "type": "number",
      "title": { "en": "Minutes until departure", "nl": "Minuten tot vertrek", "de": "Minuten bis Abfahrt" }, "example": 25 },
    { "name": "summary", "type": "string",
      "title": { "en": "Summary", "nl": "Samenvatting", "de": "Übersicht" }, "example": "23:35 (last train tonight) — departs in 25 min" }
  ]
}
