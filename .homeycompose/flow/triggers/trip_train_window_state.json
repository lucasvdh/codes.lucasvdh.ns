{
  "id": "trip_train_window_state",
  "title": {
    "en": "Train state changed in time window",
    "nl": "Treinstatus gewijzigd in tijdvenster",
    "de": "Zugstatus im Zeitfenster geändert"
  },
  "titleFormatted": {
    "en": "Train between [[time_from]] and [[time_to]]: [[condition]]",
    "nl": "Trein tussen [[time_from]] en [[time_to]]: [[condition]]",
    "de": "Zug zwischen [[time_from]] und [[time_to]]: [[condition]]"
  },
  "args": [
    { "name": "device", "type": "device", "filter": "driver_id=trip" },
    { "name": "time_from", "type": "time",
      "title": { "en": "From time", "nl": "Vanaf tijd", "de": "Ab Uhrzeit" },
      "placeholder": { "en": "08:00", "nl": "08:00", "de": "08:00" } },
    { "name": "time_to", "type": "time",
      "title": { "en": "Until time", "nl": "Tot tijd", "de": "Bis Uhrzeit" },
      "placeholder": { "en": "08:30", "nl": "08:30", "de": "08:30" } },
    {
      "name": "condition",
      "type": "dropdown",
      "title": { "en": "Match on", "nl": "Activeer bij", "de": "Auslösen bei" },
      "values": [
        { "id": "any",       "label": { "en": "Any change",      "nl": "Elke wijziging",   "de": "Jede Änderung" } },
        { "id": "cancelled", "label": { "en": "Became cancelled","nl": "Werd uitgevallen","de": "Wurde ausgefallen" } },
        { "id": "busy",      "label": { "en": "Became busy (medium+)","nl": "Werd druk (gemiddeld+)","de": "Wurde voll (mittel+)" } },
        { "id": "very_busy", "label": { "en": "Became very busy (high)","nl": "Werd extra druk (hoog)","de": "Wurde sehr voll (hoch)" } },
        { "id": "shorter",   "label": { "en": "Shorter train announced","nl": "Kortere trein aangekondigd","de": "Kürzerer Zug angekündigt" } },
        { "id": "delayed",   "label": { "en": "Delay increased",  "nl": "Vertraging toegenomen", "de": "Verspätung gestiegen" } }
      ]
    }
  ],
  "tokens": [
    { "name": "departure_time", "type": "string",
      "title": { "en": "Departure", "nl": "Vertrek", "de": "Abfahrt" }, "example": "08:19" },
    { "name": "destination", "type": "string",
      "title": { "en": "Destination", "nl": "Bestemming", "de": "Ziel" }, "example": "Kropswolde" },
    { "name": "event", "type": "string",
      "title": { "en": "Event", "nl": "Gebeurtenis", "de": "Ereignis" }, "example": "became_cancelled" },
    { "name": "crowd_level", "type": "string",
      "title": { "en": "Crowd level", "nl": "Drukte", "de": "Auslastung" }, "example": "HIGH" },
    { "name": "cancelled", "type": "boolean",
      "title": { "en": "Cancelled", "nl": "Uitgevallen", "de": "Ausgefallen" }, "example": false },
    { "name": "delay_minutes", "type": "number",
      "title": { "en": "Delay (min)", "nl": "Vertraging (min)", "de": "Verspätung (Min)" }, "example": 0 },
    { "name": "shorter_train", "type": "boolean",
      "title": { "en": "Shorter train", "nl": "Kortere trein", "de": "Kürzerer Zug" }, "example": false },
    { "name": "track", "type": "string",
      "title": { "en": "Track", "nl": "Spoor", "de": "Gleis" }, "example": "5a" },
    { "name": "summary", "type": "string",
      "title": { "en": "Summary", "nl": "Samenvatting", "de": "Übersicht" }, "example": "08:19 became cancelled" }
  ]
}
