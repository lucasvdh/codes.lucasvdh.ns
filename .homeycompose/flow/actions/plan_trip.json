{
  "id": "plan_trip",
  "title": {
    "en": "Plan a trip",
    "nl": "Plan een reis",
    "de": "Reise planen"
  },
  "titleFormatted": {
    "en": "Plan trip from [[from]] to [[to]]",
    "nl": "Plan reis van [[from]] naar [[to]]",
    "de": "Reise planen von [[from]] nach [[to]]"
  },
  "args": [
    { "name": "from", "type": "autocomplete",
      "title": { "en": "From", "nl": "Van", "de": "Von" },
      "placeholder": { "en": "Origin station", "nl": "Vertrekstation", "de": "Abfahrtsbahnhof" } },
    { "name": "to", "type": "autocomplete",
      "title": { "en": "To", "nl": "Naar", "de": "Nach" },
      "placeholder": { "en": "Destination station", "nl": "Aankomststation", "de": "Zielbahnhof" } }
  ],
  "tokens": [
    { "name": "departure_time", "type": "string",
      "title": { "en": "Departure", "nl": "Vertrek", "de": "Abfahrt" }, "example": "08:42" },
    { "name": "arrival_time", "type": "string",
      "title": { "en": "Arrival", "nl": "Aankomst", "de": "Ankunft" }, "example": "09:30" },
    { "name": "duration_minutes", "type": "number",
      "title": { "en": "Duration (min)", "nl": "Reistijd (min)", "de": "Dauer (Min)" }, "example": 48 },
    { "name": "transfers", "type": "number",
      "title": { "en": "Transfers", "nl": "Overstappen", "de": "Umstiege" }, "example": 1 },
    { "name": "delay_minutes", "type": "number",
      "title": { "en": "Delay (min)", "nl": "Vertraging (min)", "de": "Verspätung (Min)" }, "example": 0 },
    { "name": "departure_track", "type": "string",
      "title": { "en": "Track", "nl": "Spoor", "de": "Gleis" }, "example": "5a" },
    { "name": "cancelled", "type": "boolean",
      "title": { "en": "Cancelled", "nl": "Uitgevallen", "de": "Ausgefallen" }, "example": false },
    { "name": "price_eur", "type": "number",
      "title": { "en": "Price (€, 2nd class single)", "nl": "Prijs (€, 2e klas enkel)", "de": "Preis (€, 2. Klasse einfach)" }, "example": 12.5 },
    { "name": "co2_kg", "type": "number",
      "title": { "en": "CO2 (kg)", "nl": "CO2 (kg)", "de": "CO2 (kg)" }, "example": 0.8 },
    { "name": "crowd_level", "type": "string",
      "title": { "en": "Crowd level", "nl": "Drukte", "de": "Auslastung" }, "example": "MEDIUM" },
    { "name": "booking_url", "type": "string",
      "title": { "en": "Booking URL", "nl": "Boekings-URL", "de": "Buchungs-URL" }, "example": "https://www.ns.nl/..." }
  ]
}
