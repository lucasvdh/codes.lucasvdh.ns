{
  "id": "next_departure",
  "title": {
    "en": "Get next departure",
    "nl": "Haal volgende vertrek op",
    "de": "Nächste Abfahrt abrufen"
  },
  "titleFormatted": {
    "en": "Next departure from [[station]] heading [[direction]]",
    "nl": "Volgende vertrek van [[station]] richting [[direction]]",
    "de": "Nächste Abfahrt von [[station]] Richtung [[direction]]"
  },
  "args": [
    { "name": "station", "type": "autocomplete",
      "title": { "en": "Station", "nl": "Station", "de": "Bahnhof" },
      "placeholder": { "en": "Station", "nl": "Station", "de": "Bahnhof" } },
    { "name": "direction", "type": "text", "required": false,
      "title": { "en": "Direction (optional)", "nl": "Richting (optioneel)", "de": "Richtung (optional)" },
      "placeholder": { "en": "Filter on destination, e.g. Amsterdam",
                       "nl": "Filter op bestemming, bv. Amsterdam",
                       "de": "Nach Ziel filtern, z. B. Amsterdam" } }
  ],
  "tokens": [
    { "name": "departure_time", "type": "string",
      "title": { "en": "Departure", "nl": "Vertrek", "de": "Abfahrt" }, "example": "08:42" },
    { "name": "destination", "type": "string",
      "title": { "en": "Destination", "nl": "Bestemming", "de": "Ziel" }, "example": "Amsterdam Centraal" },
    { "name": "track", "type": "string",
      "title": { "en": "Track", "nl": "Spoor", "de": "Gleis" }, "example": "5a" },
    { "name": "delay_minutes", "type": "number",
      "title": { "en": "Delay (min)", "nl": "Vertraging (min)", "de": "Verspätung (Min)" }, "example": 0 },
    { "name": "cancelled", "type": "boolean",
      "title": { "en": "Cancelled", "nl": "Uitgevallen", "de": "Ausgefallen" }, "example": false },
    { "name": "train_type", "type": "string",
      "title": { "en": "Train type", "nl": "Treinsoort", "de": "Zugart" }, "example": "IC" }
  ]
}
